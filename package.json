{
  "name": "chronos-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "NODE_ENV=cli ts-node --transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "NODE_ENV=cli pnpm run typeorm migration:generate -d ./src/config/data-source.ts migrations/Init",
    "migration:create": "NODE_ENV=cli pnpm run typeorm migration:create -d ./src/config/data-source.ts",
    "migration:run": "NODE_ENV=cli pnpm run typeorm migration:run -d ./src/config/data-source.ts",
    "migration:revert": "NODE_ENV=cli pnpm run typeorm migration:revert -d ./src/config/data-source.ts",
    "typeorm-extension": "NODE_ENV=cli ts-node --transpile-only -r tsconfig-paths/register ./node_modules/typeorm-extension/bin/cli.mjs",
    "seed:run": "NODE_ENV=cli pnpm run typeorm-extension seed:run -d ./src/config/data-source.ts",
    "seed:create": "NODE_ENV=cli pnpm run typeorm-extension seed:create -r ./seeds"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/typeorm": "11.0.1",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.4.2",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/swagger": "11.3.0",
    "@nestjs/testing": "11.1.19",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@types/supertest": "6.0.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typeorm-extension": "3.9.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
